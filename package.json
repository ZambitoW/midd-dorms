{
  "name": "project-camelshump",
  "version": "0.1.0",
  "description": "MiddDorms - a site for Middlebury College students to view and post reviews about the Middlebury dorm buildings  ",
  "private": true,
  "contributors": [
    "Danny Smith <dpsmith@middlebury.edu>",
    "Moon Granda <mgranda@middlebury.edu>",
    "Jackson Stone <jston@middlebury.edu>",
    "William Zambito <wzambito@middlebury.edu>",
    "Swikriti Kharel <skharel@middlebury.edu>",
    "Ashley Townsend <aatownsend@middlebury.edu>"
  ],
  "scripts": {
    "dev": "node ./dev-runner.js next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "lint": "eslint src",
    "prepare": "node .husky/install.mjs",
    "predev": "docker compose -f docker-compose.dev.yml up -d",
    "postdev": "docker compose -f docker-compose.dev.yml down"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^7.0.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "module-alias": "^2.2.3",
    "nanoid": "^5.1.5",
    "next": "15.1.7",
    "next-auth": "^4.24.11",
    "next-connect": "^1.0.0",
    "objection": "^3.1.5",
    "pg": "^8.14.1",
    "prop-types": "^15.8.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sqlite3": "^5.1.7"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.{js,mjs,css,md,json,jsx}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "cross-env": "^7.0.3",
    "eslint": "9.22.0",
    "eslint-config-next": "15.2.2",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-testing-library": "^7.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-extended": "^4.0.2",
    "knex": "^3.1.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "sharp"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "check-prop-types>prop-types": "15.8"
      }
    }
  }
}
